# Override the vault path used by the indexer at build time.
# Default: ./vault/system_design (bundled with the repo)
# VAULT_PATH=/absolute/path/to/your/system_design

# Subpath for the built site (used when deploying under /<repo>/ on GitHub
# Pages). Most hosts (Vercel, Netlify, Docker) keep it at "/".
# VITE_BASE_PATH=/hld-architect-copilot/
